      <aliases enabled='yes' />
      <column caption='Total Revenue (Completed)' datatype='integer' name='[Calculation_0360096825237505]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [booking_complete]= 1 THEN [booking_amount] ELSE 0 END' />
      </column>
      <column caption='Completion Rate' datatype='real' name='[Calculation_0360096827150339]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([booking_complete])/ COUNT([booking_complete])' />
      </column>
      <column caption='Total Completed Booking' datatype='integer' name='[Calculation_0360096827764740]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [booking_complete] = 1 THEN 1 END' />
      </column>
      <column caption='Number of Records' datatype='integer' name='[Calculation_0360096835674117]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Flight number])' />
      </column>
      <column caption='Is Complete' datatype='boolean' name='[Calculation_0360096836530182]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[booking_complete] = 1' />
      </column>
